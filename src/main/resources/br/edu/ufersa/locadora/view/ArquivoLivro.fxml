<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<!--
    ArquivoLivro.fxml  —  Tela completa de Acervo (aba Livros ativa)
    Navbar idêntica ao NavArea.fxml (ToggleGroup "NavItems")
    Salvar em: src/main/resources/br/edu/ufersa/locadora/view/ArquivoLivro.fxml
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.locadora.controllers.ArquivoLivroController"
            prefWidth="848" prefHeight="620"
            styleClass="root-livro"
            stylesheets="@../css/ArquivoLivro.css">

    <!-- ══════════════════════════════════════════════════════════════
         NAVBAR — estrutura idêntica ao NavArea.fxml
    ══════════════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">

            <!-- Logo -->
            <Label styleClass="navbar-brand" contentDisplay="LEFT" graphicTextGap="8">
                <graphic>
                    <ImageView fitHeight="30" fitWidth="30"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../images/vynil-yellow.png"/></image>
                    </ImageView>
                </graphic>
                Cultura Viva
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Acervo — SELECIONADO (aba ativa na navbar) -->
            <ToggleButton fx:id="navAcervo" id="navAcervo"
                          text="Acervo" selected="true"
                          styleClass="nav-toggle"
                          onAction="#handleNavAcervo">
                <toggleGroup><ToggleGroup fx:id="NavItems"/></toggleGroup>
                <graphic>
                    <HBox spacing="4" alignment="CENTER">
                        <ImageView fitHeight="22" fitWidth="22"
                                   pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/disc.png"/></image>
                        </ImageView>
                        <ImageView fitHeight="18" fitWidth="18"
                                   pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/book.png"/></image>
                        </ImageView>
                    </HBox>
                </graphic>
                <font><Font name="Impact" size="13"/></font>
            </ToggleButton>

            <ToggleButton fx:id="navAlugueis" id="navAlugueis"
                          text="Relatório"
                          styleClass="nav-toggle"
                          toggleGroup="$NavItems"
                          onAction="#handleNavRelatorio">
                <graphic>
                    <ImageView fitHeight="22" fitWidth="22"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../images/report.png"/></image>
                    </ImageView>
                </graphic>
                <font><Font name="Impact" size="13"/></font>
            </ToggleButton>

            <ToggleButton fx:id="navCadastros" id="navCadastros"
                          text="Cadastros"
                          styleClass="nav-toggle"
                          toggleGroup="$NavItems"
                          onAction="#handleNavCadastros">
                <graphic>
                    <ImageView fitHeight="22" fitWidth="22"
                               pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../images/user.png"/></image>
                    </ImageView>
                </graphic>
                <font><Font name="Impact" size="13"/></font>
            </ToggleButton>

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════════
         CONTEÚDO CENTRAL
    ══════════════════════════════════════════════════════════════ -->
    <center>
        <HBox styleClass="content-area" spacing="0" alignment="TOP_LEFT">

            <!-- ── TABELA + ABAS ───────────────────────────────────── -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">

                <!-- Linha das abas -->
                <HBox spacing="0" alignment="BOTTOM_LEFT">

                    <!-- ABA LIVROS — ATIVA (roxa, maior, arredondada topo) -->
                    <VBox styleClass="tab-livros-ativa" alignment="CENTER" spacing="6"
                          onMouseClicked="#navegarLivros" cursor="HAND"
                          minWidth="200">
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitHeight="24" fitWidth="24"
                                       pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@../images/book.png"/></image>
                            </ImageView>
                            <Label text="Livros" styleClass="tab-livros-ativa-label"/>
                        </HBox>
                    </VBox>

                    <!-- ABA DISCOS — inativa (creme) -->
                    <VBox styleClass="tab-discos-inativa" alignment="CENTER" spacing="6"
                          onMouseClicked="#navegarDiscos" cursor="HAND"
                          minWidth="180">
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitHeight="22" fitWidth="22"
                                       pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@../images/disc.png"/></image>
                            </ImageView>
                            <Label text="Discos" styleClass="tab-discos-inativa-label"/>
                        </HBox>
                    </VBox>

                    <!-- Preenche o resto da largura com fundo creme -->
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-background-color:#F0E4C0; -fx-background-radius:12 12 0 0;"/>
                </HBox>

                <!-- ── TABELA DE LIVROS ─────────────────────────────── -->
                <VBox styleClass="tabela-container" VBox.vgrow="ALWAYS" spacing="0">

                    <!-- Cabeçalho amarelo — Imagem | Título | Data | Autor(a) -->
                    <HBox styleClass="tabela-header" alignment="CENTER_LEFT" spacing="0">
                        <Label text="Imagem"   styleClass="tabela-header-label"
                               prefWidth="90"  minWidth="90"/>
                        <Label text="Título"   styleClass="tabela-header-label"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Label text="Data"     styleClass="tabela-header-label"
                               prefWidth="120" minWidth="100"/>
                        <Label text="Autor(a)" styleClass="tabela-header-label"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Label text="" prefWidth="56"/>
                    </HBox>

                    <!-- Preview linha 1 (Scene Builder) -->
                    <HBox styleClass="linha-livro" alignment="CENTER_LEFT" spacing="14">
                        <StackPane styleClass="img-placeholder">
                            <Label text="🖼" styleClass="img-icon"/>
                        </StackPane>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Label text="01/02//2023"  styleClass="cell-text" prefWidth="120"/>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <VBox alignment="CENTER" spacing="4" prefWidth="56">
                            <Button text="✏" styleClass="btn-editar"/>
                            <Button text="🗑" styleClass="btn-excluir"/>
                        </VBox>
                    </HBox>

                    <!-- Preview linha 2 -->
                    <HBox styleClass="linha-livro" alignment="CENTER_LEFT" spacing="14">
                        <StackPane styleClass="img-placeholder">
                            <Label text="🖼" styleClass="img-icon"/>
                        </StackPane>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Label text="01/02//2023"  styleClass="cell-text" prefWidth="120"/>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <VBox alignment="CENTER" spacing="4" prefWidth="56">
                            <Button text="✏" styleClass="btn-editar"/>
                            <Button text="🗑" styleClass="btn-excluir"/>
                        </VBox>
                    </HBox>

                    <!-- Preview linha 3 -->
                    <HBox styleClass="linha-livro" alignment="CENTER_LEFT" spacing="14">
                        <StackPane styleClass="img-placeholder">
                            <Label text="🖼" styleClass="img-icon"/>
                        </StackPane>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Label text="01/02//2023"  styleClass="cell-text" prefWidth="120"/>
                        <Label text="O pequeno príncipe" styleClass="cell-text"
                               HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <VBox alignment="CENTER" spacing="4" prefWidth="56">
                            <Button text="✏" styleClass="btn-editar"/>
                            <Button text="🗑" styleClass="btn-excluir"/>
                        </VBox>
                    </HBox>

                    <!-- ScrollPane dinâmico — ativado e preenchido pelo controller -->
                    <ScrollPane fx:id="scrollTabela"
                                fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                VBox.vgrow="ALWAYS"
                                style="-fx-background:transparent;
                                       -fx-background-color:transparent;
                                       -fx-border-color:transparent;"
                                visible="false" managed="false">
                        <VBox fx:id="listaLivros" spacing="0"
                              style="-fx-background-color:transparent;"/>
                    </ScrollPane>

                </VBox>
            </VBox>

            <!-- ── PAINEL FORMULÁRIO — oculto por padrão ────────────── -->
            <VBox fx:id="painelForm" styleClass="form-panel"
                  spacing="8" visible="false" managed="false">

                <Label fx:id="lblFormTitulo" text="Novo Livro" styleClass="form-title"/>

                <Label text="Título:" styleClass="form-label"/>
                <TextField fx:id="tfTitulo"    styleClass="form-field" promptText="Ex: Dom Casmurro"/>

                <Label text="Autor:" styleClass="form-label"/>
                <TextField fx:id="tfAutor"     styleClass="form-field" promptText="Ex: Machado de Assis"/>

                <Label text="Gênero:" styleClass="form-label"/>
                <TextField fx:id="tfGenero"    styleClass="form-field" promptText="Ex: Romance"/>

                <Label text="Data de lançamento (dd/MM/yyyy):" styleClass="form-label"/>
                <TextField fx:id="tfData"      styleClass="form-field" promptText="01/01/2000"/>

                <Label text="Qtd. exemplares:" styleClass="form-label"/>
                <TextField fx:id="tfQtd"       styleClass="form-field" promptText="0"/>

                <Label text="Valor diária (R$):" styleClass="form-label"/>
                <TextField fx:id="tfValor"     styleClass="form-field" promptText="0.00"/>

                <Label text="Qtd. de páginas:" styleClass="form-label"/>
                <TextField fx:id="tfPaginas"   styleClass="form-field" promptText="0"/>

                <Label fx:id="lblFormMsg" text="" styleClass="form-msg" wrapText="true"/>

                <HBox spacing="8" style="-fx-padding:6 0 0 0;">
                    <Button text="Salvar"   styleClass="btn-salvar"   onAction="#salvarLivro"/>
                    <Button text="Cancelar" styleClass="btn-cancelar" onAction="#fecharForm"/>
                </HBox>
            </VBox>

        </HBox>
    </center>

    <!-- ══════════════════════════════════════════════════════════════
         BARRA INFERIOR
    ══════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="bottombar" alignment="CENTER_LEFT" spacing="10">

            <Label text="▼" style="-fx-text-fill:#F8EED1; -fx-font-size:13px;"/>
            <TextField fx:id="tfPesquisa"
                       styleClass="search-field"
                       promptText="Pesquisar"
                       onAction="#pesquisar"/>
            <Label text="🔍"
                   style="-fx-text-fill:#7A6A5A; -fx-font-size:13px;
                          -fx-translate-x:-32px; -fx-mouse-transparent:true;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Logout ➜"
                    styleClass="btn-logout-bottom"
                    onAction="#handleLogout"/>

            <Button fx:id="btnAdicionar"
                    text="Adicionar novo livro ＋"
                    styleClass="btn-adicionar"
                    onAction="#abrirFormNovo"/>
        </HBox>
    </bottom>

</BorderPane>
