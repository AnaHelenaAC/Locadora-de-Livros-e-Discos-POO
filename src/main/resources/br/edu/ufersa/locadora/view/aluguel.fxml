<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="520" prefWidth="820" styleClass="root-pane" stylesheets="@../css/aluguel.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.locadora.controllers.AluguelController">
   <top>
      <HBox prefHeight="100.0" prefWidth="200.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <children>
            <ButtonBar prefHeight="40.0" prefWidth="200.0" />
         </children></HBox>
   </top>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" styleClass="bottom-bar" BorderPane.alignment="CENTER" />
   </bottom>
   <center>
      <VBox prefHeight="200.0" prefWidth="820.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER" prefHeight="60.0" prefWidth="820.0" spacing="10.0">
               <children>
                  <ComboBox fx:id="comboTipo" prefWidth="150.0" />
                  <TextField fx:id="txtCliente" promptText="Buscar por CPF/Cliente" />
                  <Button mnemonicParsing="false" onAction="#aoFiltrar" text="Filtrar" />
                  <Button mnemonicParsing="false" onAction="#aoMostrarTudo" text="Mostrar Tudo" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="362.0" prefWidth="820.0" spacing="10.0">
               <children>
                  <TableView fx:id="tabelaAluguel" maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="380.0">
                    <columns>
                      <TableColumn fx:id="colAluguelID" prefWidth="75.0" text="ID Aluguel" />
                      <TableColumn fx:id="colCliente" prefWidth="75.0" text="CPF" />
                        <TableColumn fx:id="colInicio" prefWidth="75.0" text="Data Início" />
                        <TableColumn fx:id="colPrevista" prefWidth="75.0" text="Data Prevista" />
                        <TableColumn fx:id="colTotal" prefWidth="75.0" text="A Pagar" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <VBox alignment="CENTER" prefWidth="380.0">
                     <children>
                        <TableView fx:id="tabelaItens" maxHeight="-Infinity" maxWidth="-Infinity">
                          <columns>
                            <TableColumn fx:id="colItemId" prefWidth="75.0" text="Tipo" />
                              <TableColumn fx:id="colTitulo" prefWidth="75.0" text="Título" />
                              <TableColumn fx:id="colDevolocao" prefWidth="75.0" text="Devolução" />
                              <TableColumn fx:id="colValor" prefWidth="75.0" text="Valor" />
                              <TableColumn fx:id="colMulta" prefWidth="75.0" text="Multa" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#aoRegistrarDevolucao" text="Registrar Devolução" />
                           </children>
                           <padding>
                              <Insets bottom="20.0" top="20.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
