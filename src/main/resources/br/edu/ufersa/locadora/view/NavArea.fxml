<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #fdf2d4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.locadora.controllers.NavAreaController">
   <top>
      <HBox prefHeight="50.0" prefWidth="600.0" style="-fx-background-color: #2E1A47;" BorderPane.alignment="CENTER">
         <children>
            <BorderPane>
               <children>
                  <Text fill="#fdf1a5" strokeType="OUTSIDE" strokeWidth="0.0" text="Cultura Viva" textAlignment="CENTER">
