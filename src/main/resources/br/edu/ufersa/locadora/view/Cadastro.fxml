<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    Tela de Cadastros — Cultura Viva
    Salvar em: src/main/resources/br/edu/ufersa/locadora/view/cadastros.fxml
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.locadora.controllers.CadastrosController"
            prefWidth="840" prefHeight="580"
            style="-fx-background-color: #F8EED1;">

    <!-- ══ BARRA SUPERIOR ══════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #2E1A47;
                     -fx-min-height: 56px; -fx-pref-height: 56px;">
            <padding><Insets left="16" right="0" top="0" bottom="0"/></padding>

            <Label text="🎵"
                   style="-fx-font-size:24px; -fx-text-fill:#F2D888; -fx-padding: 0 4 0 0;"/>
            <Label text="Cultura Viva"
                   style="-fx-text-fill:#F2D888; -fx-font-family:Georgia;
                          -fx-font-size:22px; -fx-font-weight:bold; -fx-padding: 0 24 0 4;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnNavAcervo" text="⊙ ▤   Acervo"
                    onAction="#navegarAcervo"
                    style="-fx-background-color:transparent; -fx-text-fill:#C8B8E8;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;"/>

            <Button fx:id="btnNavRelatorio" text="📋   Relatório"
                    onAction="#navegarRelatorio"
                    style="-fx-background-color:transparent; -fx-text-fill:#C8B8E8;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;"/>

            <Button fx:id="btnNavCadastros" text="👤   Cadastros"
                    onAction="#navegarCadastros"
                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:#F2D888;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;
                           -fx-border-color:transparent transparent #F2D888 transparent;
                           -fx-border-width:0 0 2 0;"/>
        </HBox>
    </top>

    <!-- ══ CONTEÚDO CENTRAL ══════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color:#F8EED1; -fx-padding: 24 20 0 20;" spacing="14">

            <!-- Linha: título + abas Funcionário / Cliente -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="Cadastro de Novo Cliente"
                       style="-fx-text-fill:#2E1A47; -fx-font-family:Georgia;
                              -fx-font-size:20px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Aba Funcionário (inativa) — visível só para gerente -->
                <Button fx:id="btnAbaFuncionario" text="Funcionário"
                        onAction="#mostrarFuncionarios"
                        style="-fx-background-color:#F8EED1; -fx-text-fill:#2E1A47;
                               -fx-font-size:13px; -fx-font-weight:bold;
                               -fx-background-radius:20 0 0 20;
                               -fx-border-color:#2E1A47; -fx-border-width:1.5;
                               -fx-border-radius:20 0 0 20;
                               -fx-padding:8 20 8 20; -fx-cursor:hand;"
                        visible="false" managed="false"/>

                <!-- Aba Cliente (ativa) -->
                <Button fx:id="btnAbaCliente" text="Cliente"
                        onAction="#mostrarClientes"
                        style="-fx-background-color:#2E1A47; -fx-text-fill:#F8EED1;
                               -fx-font-size:13px; -fx-font-weight:bold;
                               -fx-background-radius:20; -fx-border-color:#2E1A47;
                               -fx-border-width:1.5; -fx-border-radius:20;
                               -fx-padding:8 24 8 24; -fx-cursor:hand;"/>
            </HBox>

            <!-- Tabela principal -->
            <VBox spacing="0"
                  style="-fx-background-color:#FFFFFF;
                         -fx-background-radius:14;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.12),10,0,1,3);">

                <!-- Cabeçalho da tabela -->
                <HBox style="-fx-background-color:#2E1A47;
                             -fx-background-radius:12 12 0 0;
                             -fx-padding:12 16 12 16;"
                      alignment="CENTER_LEFT" spacing="0">
                    <Label text="Nome"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="Endereço"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="CPF"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           prefWidth="160"/>
                </HBox>

                <!-- Linha de adição (campo + botão +) -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 16;
                             -fx-border-color:transparent transparent #E8DCC8 transparent;
                             -fx-border-width:0 0 1 0;
                             -fx-background-color:#FAFAF8;">

                    <!-- Botão + circular -->
                    <Button text="＋" onAction="#abrirFormNovo"
                            style="-fx-background-color:#2E1A47; -fx-text-fill:white;
                                   -fx-font-size:18px; -fx-font-weight:bold;
                                   -fx-background-radius:50; -fx-min-width:36px;
                                   -fx-min-height:36px; -fx-pref-width:36px;
                                   -fx-pref-height:36px; -fx-cursor:hand;
                                   -fx-padding:0;"/>

                    <!-- Campos de adição rápida (placeholders visuais) -->
                    <TextField fx:id="tfNome" promptText="Nome"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:8 14 8 14;
                                      -fx-font-size:13px; -fx-pref-height:36px;"/>
                    <TextField fx:id="tfEndereco" promptText="Endereço"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:8 14 8 14;
                                      -fx-font-size:13px; -fx-pref-height:36px;"/>
                    <TextField fx:id="tfCpf" promptText="CPF"
                               prefWidth="160"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:8 14 8 14;
                                      -fx-font-size:13px; -fx-pref-height:36px;"/>
                </HBox>

                <!-- Lista de registros (ScrollPane com VBox dinâmica) -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            prefHeight="320"
                            style="-fx-background:transparent; -fx-background-color:transparent;
                                   -fx-border-color:transparent;">
                    <VBox fx:id="listaRegistros" spacing="0"
                          style="-fx-background-color:transparent;"/>
                </ScrollPane>

            </VBox>

            <!-- Mensagem de feedback -->
            <Label fx:id="lblMsg" text="" wrapText="true"
                   style="-fx-font-size:12px; -fx-text-fill:#C0392B;"/>

        </VBox>
    </center>

    <!-- ══ BARRA INFERIOR — apenas Logout ══════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#F8EED1; -fx-padding:12 20 14 20;">
            <Button text="Logout ➜" onAction="#handleLogout"
                    style="-fx-background-color:#D1203A; -fx-text-fill:white;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-background-radius:20; -fx-padding:8 22 8 22;
                           -fx-cursor:hand;"/>
        </HBox>
    </bottom>

</BorderPane>
