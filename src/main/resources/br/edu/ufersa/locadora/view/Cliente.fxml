<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    Tela de Cadastro de Clientes — Cultura Viva
    Salvar em: src/main/resources/br/edu/ufersa/locadora/view/cliente.fxml
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.locadora.controllers.ClienteController"
            prefWidth="748" prefHeight="540"
            style="-fx-background-color: #F8EED1;">

    <!-- ══ BARRA SUPERIOR ══════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:#2E1A47;
                     -fx-min-height:56px; -fx-pref-height:56px;">
            <padding><Insets left="16" right="0" top="0" bottom="0"/></padding>

            <Label text="🎵"
                   style="-fx-font-size:24px; -fx-text-fill:#F2D888; -fx-padding:0 4 0 0;"/>
            <Label text="Cultura Viva"
                   style="-fx-text-fill:#F2D888; -fx-font-family:Georgia;
                          -fx-font-size:22px; -fx-font-weight:bold; -fx-padding:0 24 0 4;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⊙ ▤   Acervo" onAction="#navegarAcervo"
                    style="-fx-background-color:transparent; -fx-text-fill:#C8B8E8;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;"/>
            <Button text="📋   Relatório" onAction="#navegarRelatorio"
                    style="-fx-background-color:transparent; -fx-text-fill:#C8B8E8;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;"/>
            <Button text="👤   Cadastros" onAction="#navegarCadastros"
                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:#F2D888;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-padding:18 22 16 22; -fx-background-radius:0; -fx-cursor:hand;
                           -fx-border-color:transparent transparent #F2D888 transparent;
                           -fx-border-width:0 0 2 0;"/>
        </HBox>
    </top>

    <!-- ══ CONTEÚDO CENTRAL ══════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color:#F8EED1; -fx-padding:22 18 0 18;" spacing="12">

            <!-- Título + aba Cliente (única, ativa) -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label text="Cadastro de Novo Cliente"
                       style="-fx-text-fill:#2E1A47; -fx-font-family:Georgia;
                              -fx-font-size:20px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Só aba Cliente (sem aba Funcionário para funcionários) -->
                <Button text="Cliente"
                        style="-fx-background-color:#2E1A47; -fx-text-fill:#F8EED1;
                               -fx-font-size:13px; -fx-font-weight:bold;
                               -fx-background-radius:20 20 0 0;
                               -fx-border-color:#2E1A47; -fx-border-width:1.5 1.5 0 1.5;
                               -fx-border-radius:20 20 0 0;
                               -fx-padding:8 28 8 28; -fx-cursor:hand;"/>
            </HBox>

            <!-- Tabela -->
            <VBox spacing="0"
                  style="-fx-background-color:#FFFFFF; -fx-background-radius:0 14 14 14;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.12),10,0,1,3);">

                <!-- Cabeçalho roxo -->
                <HBox alignment="CENTER_LEFT" spacing="0"
                      style="-fx-background-color:#2E1A47; -fx-background-radius:0 10 0 0;
                             -fx-padding:12 16 12 52;">
                    <Label text="Nome"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="Endereço"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="CPF"
                           style="-fx-text-fill:#F8EED1; -fx-font-weight:bold; -fx-font-size:13px;"
                           prefWidth="150"/>
                    <Label text="" prefWidth="36"/>
                </HBox>

                <!-- Linha de adição rápida -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 10; -fx-background-color:#FAFAF8;
                             -fx-border-color:transparent transparent #DDD5C5 transparent;
                             -fx-border-width:0 0 1.5 0;">
                    <Button text="＋" onAction="#adicionarCliente"
                            style="-fx-background-color:#2E1A47; -fx-text-fill:white;
                                   -fx-font-size:18px; -fx-font-weight:bold;
                                   -fx-background-radius:50; -fx-min-width:34px;
                                   -fx-min-height:34px; -fx-pref-width:34px;
                                   -fx-pref-height:34px; -fx-padding:0; -fx-cursor:hand;"/>
                    <TextField fx:id="tfNome" promptText="Nome"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:7 14 7 14;
                                      -fx-font-size:13px; -fx-pref-height:34px;"/>
                    <TextField fx:id="tfEndereco" promptText="Endereço"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:7 14 7 14;
                                      -fx-font-size:13px; -fx-pref-height:34px;"/>
                    <TextField fx:id="tfCpf" promptText="CPF"
                               prefWidth="150"
                               style="-fx-background-color:#E8E0D8; -fx-background-radius:20;
                                      -fx-border-color:transparent; -fx-padding:7 14 7 14;
                                      -fx-font-size:13px; -fx-pref-height:34px;"/>
                    <Label text="" prefWidth="36"/>
                </HBox>

                <!-- Linhas de preview -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 10; -fx-background-color:#FFFFFF;
                             -fx-border-color:transparent transparent #EAE0D0 transparent;
                             -fx-border-width:0 0 1 0;">
                    <Label text="👤" style="-fx-background-color:#C0B8C8; -fx-background-radius:50;
                           -fx-min-width:34px; -fx-min-height:34px; -fx-pref-width:34px;
                           -fx-pref-height:34px; -fx-font-size:16px; -fx-alignment:center; -fx-text-fill:white;"/>
                    <Label text="Lucas Silva Moura" style="-fx-font-size:13px; -fx-text-fill:#2E1A47;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="lucas.moura245@gmail.com" style="-fx-font-size:13px; -fx-text-fill:#555555;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="783.076.170-14" style="-fx-font-size:13px; -fx-text-fill:#555555;" prefWidth="150"/>
                    <VBox alignment="CENTER" spacing="1" prefWidth="36">
                        <Label text="✏" style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-cursor:hand;"/>
                        <Label text="🗑" style="-fx-text-fill:#AAAAAA; -fx-font-size:12px; -fx-cursor:hand;"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 10; -fx-background-color:#FFFFFF;
                             -fx-border-color:transparent transparent #EAE0D0 transparent;
                             -fx-border-width:0 0 1 0;">
                    <Label text="👤" style="-fx-background-color:#C0B8C8; -fx-background-radius:50;
                           -fx-min-width:34px; -fx-min-height:34px; -fx-pref-width:34px;
                           -fx-pref-height:34px; -fx-font-size:16px; -fx-alignment:center; -fx-text-fill:white;"/>
                    <Label text="Guilherme Almeida Costa" style="-fx-font-size:13px; -fx-text-fill:#2E1A47;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="Gui_COSTA@gmail.com" style="-fx-font-size:13px; -fx-text-fill:#555555;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="687.383.590-06" style="-fx-font-size:13px; -fx-text-fill:#555555;" prefWidth="150"/>
                    <VBox alignment="CENTER" spacing="1" prefWidth="36">
                        <Label text="✏" style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-cursor:hand;"/>
                        <Label text="🗑" style="-fx-text-fill:#AAAAAA; -fx-font-size:12px; -fx-cursor:hand;"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 10; -fx-background-color:#FFFFFF;
                             -fx-border-color:transparent transparent #EAE0D0 transparent;
                             -fx-border-width:0 0 1 0;">
                    <Label text="👤" style="-fx-background-color:#C0B8C8; -fx-background-radius:50;
                           -fx-min-width:34px; -fx-min-height:34px; -fx-pref-width:34px;
                           -fx-pref-height:34px; -fx-font-size:16px; -fx-alignment:center; -fx-text-fill:white;"/>
                    <Label text="Bernado Fernadez Bruno" style="-fx-font-size:13px; -fx-text-fill:#2E1A47;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="BB7564@gmail.com" style="-fx-font-size:13px; -fx-text-fill:#555555;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="988.394.300-83" style="-fx-font-size:13px; -fx-text-fill:#555555;" prefWidth="150"/>
                    <VBox alignment="CENTER" spacing="1" prefWidth="36">
                        <Label text="✏" style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-cursor:hand;"/>
                        <Label text="🗑" style="-fx-text-fill:#AAAAAA; -fx-font-size:12px; -fx-cursor:hand;"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:10 16 10 10; -fx-background-color:#FFFFFF;
                             -fx-border-color:transparent transparent #EAE0D0 transparent;
                             -fx-border-width:0 0 1 0;">
                    <Label text="👤" style="-fx-background-color:#C0B8C8; -fx-background-radius:50;
                           -fx-min-width:34px; -fx-min-height:34px; -fx-pref-width:34px;
                           -fx-pref-height:34px; -fx-font-size:16px; -fx-alignment:center; -fx-text-fill:white;"/>
                    <Label text="Victor Bruno Franco" style="-fx-font-size:13px; -fx-text-fill:#2E1A47;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="FrancoVictor6675@gmail.com" style="-fx-font-size:13px; -fx-text-fill:#555555;"
                           HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Label text="093.615.990-11" style="-fx-font-size:13px; -fx-text-fill:#555555;" prefWidth="150"/>
                    <VBox alignment="CENTER" spacing="1" prefWidth="36">
                        <Label text="✏" style="-fx-text-fill:#888888; -fx-font-size:12px; -fx-cursor:hand;"/>
                        <Label text="🗑" style="-fx-text-fill:#AAAAAA; -fx-font-size:12px; -fx-cursor:hand;"/>
                    </VBox>
                </HBox>

                <!-- ScrollPane dinâmico -->
                <ScrollPane fx:id="scrollLista" fitToWidth="true"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            prefHeight="0" minHeight="0"
                            style="-fx-background:transparent; -fx-background-color:transparent;
                                   -fx-border-color:transparent;"
                            visible="false" managed="false">
                    <VBox fx:id="listaClientes" spacing="0"
                          style="-fx-background-color:transparent;"/>
                </ScrollPane>

                <Pane style="-fx-background-color:#FFFFFF; -fx-background-radius:0 0 14 14; -fx-pref-height:8px;"/>
            </VBox>

            <Label fx:id="lblMsg" text="" wrapText="true"
                   style="-fx-font-size:12px; -fx-text-fill:#C0392B;"/>
        </VBox>
    </center>

    <!-- ══ BARRA INFERIOR ROXA ══════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#2E1A47; -fx-padding:12 20 12 20; -fx-min-height:52px;">
            <Button text="Logout ➜" onAction="#handleLogout"
                    style="-fx-background-color:#D1203A; -fx-text-fill:white;
                           -fx-font-size:13px; -fx-font-weight:bold;
                           -fx-background-radius:20; -fx-padding:8 22 8 22; -fx-cursor:hand;"/>
        </HBox>
    </bottom>

</BorderPane>
